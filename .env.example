# Copy to .env (git-ignored). docker-compose reads these.

# The Security Center the viewer's "Open in SC" links point at. Match the
# TASC_SC_URL you use in tenable-attack-mapper.
SC_URL=https://localhost:8443

# Optional: override the per-plugin deep-link template for your SC version.
# {scUrl} and {pluginId} are substituted at click time.
# SC_PLUGIN_URL_TEMPLATE={scUrl}/#/analysis/vulnerabilities/sumid?sourceType=cumulative&pluginID={pluginId}
